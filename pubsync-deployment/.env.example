# Domain used by the shared eyangpet nginx. This script does not request certs.
DOMAIN=your-domain.com

# Existing eyangpet deployment directory on the server.
EYANGPET_DEPLOY_DIR=/home/ubuntu/eyangpet/eyangpet-deployment

# Docker network used by eyangpet-nginx. Check with: docker network ls | grep eyangpet
SHARED_NGINX_NETWORK=eyangpet-deployment_eyangpet-network

DB_NAME=pubsync
DB_USER=pubsync
DB_PASSWORD=change_me

PUBLISH_TIME_HOUR=8
PUBLISH_TIME_MINUTE=0

# WeChat Official Account credentials.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Same-origin production access via /pubsync/api usually does not need CORS,
# but keep the domain here for local admin/debug access.
CORS_ORIGINS=https://your-domain.com
