# Domain served by the host nginx.
DOMAIN=enceladus.online

# Backend port exposed only on 127.0.0.1 for the host nginx reverse proxy.
BACKEND_HOST_PORT=18000

# Frontend service port exposed only on 127.0.0.1 for the host nginx reverse proxy.
FRONTEND_HOST_PORT=18082

# Frontend base path for Vite builds.
FRONTEND_BASE_PATH=/PubSync/

# China mainland mirrors can make server builds much faster.
PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.cloud.tencent.com
NPM_REGISTRY=https://registry.npmmirror.com

DB_NAME=pubsync
DB_USER=pubsync
DB_PASSWORD=change_me

PUBLISH_TIME_HOUR=8
PUBLISH_TIME_MINUTE=0
AUTO_SEND_WECHAT_DRAFT=false

# Simple single-admin login for the PubSync console.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
AUTH_SECRET=change_me_to_a_random_long_secret
SESSION_HOURS=24

# AI generation. Set LLM_PROVIDER/IMAGE_PROVIDER to openai or minimax.
LLM_PROVIDER=minimax
IMAGE_PROVIDER=minimax

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1
OPENAI_IMAGE_MODEL=gpt-image-1

MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_IMAGE_MODEL=image-01

GENERATE_ARTICLE_IMAGES=true
MAX_ARTICLE_IMAGES=3
MIN_ARTICLE_IMAGES=1
NEWS_SOURCE_URLS=
INTERNATIONAL_NEWS_SOURCE_URLS=
DOMESTIC_NEWS_SOURCE_URLS=
NEWS_PER_SOURCE_LIMIT=8
INTERNATIONAL_NEWS_CANDIDATES=40
DOMESTIC_NEWS_CANDIDATES=40
NEWS_LOOKBACK_HOURS=72
MAX_NEWS_CANDIDATES=80
ARTICLE_NEWS_LIMIT=10
ARTICLE_NEWS_LOOKBACK_HOURS=72
ARTICLE_DOMESTIC_MIN=1
ARTICLE_DOMESTIC_TARGET=3
ARTICLE_DOMESTIC_MAX=4
ARTICLE_INTERNATIONAL_MIN=3
ARTICLE_INTERNATIONAL_TARGET=6
ARTICLE_INTERNATIONAL_MAX=7
PUBLIC_API_BASE_URL=https://enceladus.online/PubSync/api

# WeChat Official Account credentials.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Same-origin production access via /PubSync/api usually does not need CORS,
# but keep the domain here for local admin/debug access.
CORS_ORIGINS=https://enceladus.online,http://enceladus.online
