# Domain served by the host nginx.
DOMAIN=pubsync.example.com

# Backend port exposed only on 127.0.0.1 for the host nginx reverse proxy.
BACKEND_HOST_PORT=18000

# Frontend base path for Vite builds. Keep "/" for an independent domain.
FRONTEND_BASE_PATH=/

# China mainland mirrors can make server builds much faster.
PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.cloud.tencent.com
NPM_REGISTRY=https://registry.npmmirror.com

DB_NAME=pubsync
DB_USER=pubsync
DB_PASSWORD=change_me

PUBLISH_TIME_HOUR=8
PUBLISH_TIME_MINUTE=0

# WeChat Official Account credentials.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Same-origin production access via /api usually does not need CORS,
# but keep the domain here for local admin/debug access.
CORS_ORIGINS=https://pubsync.example.com
