# PubSync 部署配置（.env）
#
# 本文件只放「基础设施 + 密钥 + 全局应用配置」。
# 没写的项会用 app/config.py 里的默认值（默认值只有那一处，不会对不齐）。
#
# ⚠️ 每个工作空间的「业务配置」不在这里：公众号 AppID/Secret、发布时间、是否自动发草稿、
#    配图数量、新闻来源 URL、各分组篇数等，都存在数据库里，请在应用 UI 的「设置」页修改。
#    （早期这些曾放在 .env，但 config.py 并不读取，写在这里无效，已移除。）
#
# DATABASE_URL / REDIS_URL / STATIC_DIR 由 docker-compose 注入（依赖容器服务名），无需在此填写。

# ========== 部署 / 反向代理 ==========
# 宿主 nginx 对外服务的域名（供你配置 host nginx 用）。
DOMAIN=enceladus.online
# 后端/前端仅监听 127.0.0.1 的端口，由宿主 nginx 反代。
BACKEND_HOST_PORT=18000
FRONTEND_HOST_PORT=18082
# 前端 Vite 构建的 base path。
FRONTEND_BASE_PATH=/PubSync/
# 后端对外可访问的 API 根（用于公众号图片转绝对链接等）。
PUBLIC_API_BASE_URL=https://enceladus.online/PubSync/api
# 跨域来源（生产同源走 /PubSync/api 一般不需要，留作本地/调试访问）。
CORS_ORIGINS=https://enceladus.online,http://enceladus.online

# ========== 构建镜像加速（国内） ==========
PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.cloud.tencent.com
NPM_REGISTRY=https://registry.npmmirror.com

# ========== 数据库 ==========
DB_NAME=pubsync
DB_USER=pubsync
DB_PASSWORD=change_me

# ========== 登录 / 安全 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
AUTH_SECRET=change_me_to_a_random_long_secret
SESSION_HOURS=24

# ========== 后台任务队列（RQ + Redis） ==========
# false：长任务在进程内跑（无需 Redis/worker）；true：入 Redis 由 worker 执行，重启不丢。
USE_TASK_QUEUE=false

# ========== AI 提供商（openai 或 minimax） ==========
LLM_PROVIDER=minimax
IMAGE_PROVIDER=minimax
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1
OPENAI_IMAGE_MODEL=gpt-image-1
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_IMAGE_MODEL=image-01

# ========== TikHub（小红书/抖音博主蒸馏数据源） ==========
TIKHUB_BASE_URL=https://api.tikhub.io
TIKHUB_API_KEY=
TIKHUB_REQUEST_PRICE_USD=0.001
TIKHUB_MIN_REQUEST_PRICE_USD=0.001
TIKHUB_MAX_REQUEST_PRICE_USD=0.01
# 两次 TikHub 请求的最小间隔秒数，主动避免 429；0=关闭，~0.15 ≈ 10 RPS 套餐。
TIKHUB_MIN_REQUEST_INTERVAL_SECONDS=0

# ========== 视频转写 ASR（可选，需腾讯云 ASR + COS） ==========
ASR_ENABLED=false
ASR_PROVIDER=tencent_rec_task
ASR_MAX_DURATION_SECONDS=1800
ASR_POLL_INTERVAL_SECONDS=10
ASR_TIMEOUT_SECONDS=1800
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=
TENCENT_ASR_REGION=ap-shanghai
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_RES_TEXT_FORMAT=0
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=
TENCENT_COS_PREFIX=pubsync/asr
